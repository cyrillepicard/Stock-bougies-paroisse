import { useEffect, useState } from 'react'
import { supabase } from '../../lib/supabase'
import { useAuth } from '../../hooks/useAuth'
import { MinusCircle, AlertTriangle } from 'lucide-react'

export default function SortiePage() {
  const { user } = useAuth()
  const [lieux, setLieux] = useState([])
  const [bougies, setBougies] = useState([])
  const [stock, setStock] = useState([])
  const [lieuId, setLieuId] = useState('')
  const [bougieId, setBougieId] = useState('')
  const [qte, setQte] = useState('')
  const [motif, setMotif] = useState('')
  const [saving, setSaving] = useState(false)
  const [message, setMessage] = useState(null)
  const [error, setError] = useState(null)

  useEffect(() => {
    async function load() {
      const [{ data: l }, { data: b }, { data: s }] = await Promise.all([
        supabase.from('lieux').select('*').order('nom'),
        supabase.from('bougies').select('*').order('nom'),
        supabase.from('stock_par_lieu').select('*'),
      ])
      setLieux(l || [])
      setBougies(b || [])
      setStock(s || [])
    }
    load()
  }, [])

  // Bougies disponibles pour le lieu sélectionné (stock > 0)
  const bougiesDuLieu = bougies.filter(b => {
    if (!lieuId) return false
    const s = stock.find(s => s.bougie_id === b.id && s.lieu_id === lieuId)
    return s && s.quantite > 0
  })

  const stockActuel = lieuId && bougieId
    ? stock.find(s => s.bougie_id === bougieId && s.lieu_id === lieuId)
    : null

  const quantiteMax = stockActuel?.quantite ?? 0
  const quantiteSaisie = Number(qte)
  const depasseStock = quantiteSaisie > quantiteMax

  // Reset bougie si on change de lieu
  function handleLieuChange(val) {
    setLieuId(val)
    setBougieId('')
    setQte('')
    setError(null)
    setMessage(null)
  }

  function handleBougieChange(val) {
    setBougieId(val)
    setQte('')
    setError(null)
    setMessage(null)
  }

  async function handleSortie() {
    setError(null)
    setMessage(null)

    if (!lieuId || !bougieId || !qte) {
      setError('Tous les champs sont requis.')
      return
    }
    if (quantiteSaisie <= 0) {
      setError('La quantité doit être supérieure à 0.')
      return
    }
    if (depasseStock) {
      setError(`Stock insuffisant. Maximum disponible : ${quantiteMax}`)
      return
    }

    setSaving(true)

    const newQte = quantiteMax - quantiteSaisie

    await supabase.from('stock_par_lieu').upsert({
      bougie_id: bougieId,
      lieu_id: lieuId,
      quantite: newQte,
      seuil_alerte: stockActuel?.seuil_alerte ?? null,
    }, { onConflict: 'bougie_id,lieu_id' })

    await supabase.from('mouvements').insert({
      bougie_id: bougieId,
      lieu_id: lieuId,
      type: 'sortie',
      quantite: quantiteSaisie,
      motif: motif || null,
      user_email: user?.email,
    })

    // Rafraîchir le stock local
    const { data: s } = await supabase.from('stock_par_lieu').select('*')
    setStock(s || [])

    const lieuNom = lieux.find(l => l.id === lieuId)?.nom
    const bougieNom = bougies.find(b => b.id === bougieId)?.nom
    setMessage(`Sortie enregistrée : ${quantiteSaisie} × ${bougieNom} — ${lieuNom}. Stock restant : ${newQte}`)
    setQte('')
    setMotif('')
    setBougieId('')
    setSaving(false)
  }

  const alerteActive = stockActuel && stockActuel.seuil_alerte !== null
    && (quantiteMax - quantiteSaisie) <= stockActuel.seuil_alerte
    && quantiteSaisie > 0 && !depasseStock

  return (
    <div className="flex flex-col h-full">
      <div className="px-6 py-4 border-b border-stone-200 bg-white">
        <h1 className="font-serif font-bold text-xl text-stone-800">Sortie de stock</h1>
        <p className="text-stone-500 text-sm mt-0.5">Enregistrer une consommation de bougies</p>
      </div>

      <div className="flex-1 overflow-auto p-6">
        <div className="card max-w-lg mx-auto space-y-5">

          {/* Lieu */}
          <div>
            <label className="block text-sm font-medium text-stone-700 mb-1">Lieu</label>
            <select
              className="input-field"
              value={lieuId}
              onChange={e => handleLieuChange(e.target.value)}
            >
              <option value="">Sélectionner un lieu…</option>
              {lieux.map(l => <option key={l.id} value={l.id}>{l.nom}</option>)}
            </select>
          </div>

          {/* Bougie */}
          <div>
            <label className="block text-sm font-medium text-stone-700 mb-1">Type de bougie</label>
            <select
              className="input-field"
              value={bougieId}
              onChange={e => handleBougieChange(e.target.value)}
              disabled={!lieuId}
            >
              <option value="">
                {!lieuId ? 'Choisir un lieu d\'abord' : bougiesDuLieu.length === 0 ? 'Aucun stock disponible' : 'Sélectionner une bougie…'}
              </option>
              {bougiesDuLieu.map(b => {
                const s = stock.find(s => s.bougie_id === b.id && s.lieu_id === lieuId)
                return (
                  <option key={b.id} value={b.id}>
                    {b.nom} — {s?.quantite ?? 0} en stock
                  </option>
                )
              })}
            </select>
          </div>

          {/* Info stock actuel */}
          {stockActuel && bougieId && (
            <div className={`rounded-lg px-4 py-3 text-sm flex items-center justify-between
              ${stockActuel.seuil_alerte !== null && quantiteMax <= stockActuel.seuil_alerte
                ? 'bg-red-50 border border-red-200 text-red-700'
                : 'bg-stone-50 text-stone-600'
              }`}
            >
              <span>
                Stock disponible : <strong className="text-stone-800">{quantiteMax}</strong> unité{quantiteMax !== 1 ? 's' : ''}
              </span>
              {stockActuel.seuil_alerte !== null && quantiteMax <= stockActuel.seuil_alerte && (
                <span className="flex items-center gap-1 text-xs font-semibold">
                  <AlertTriangle className="w-3.5 h-3.5" /> Stock bas
                </span>
              )}
            </div>
          )}

          {/* Quantité */}
          <div>
            <label className="block text-sm font-medium text-stone-700 mb-1">Quantité à sortir</label>
            <input
              type="number"
              min="1"
              max={quantiteMax || undefined}
              className={`input-field ${depasseStock ? 'border-red-400 focus:ring-red-400' : ''}`}
              placeholder="ex : 6"
              value={qte}
              onChange={e => { setQte(e.target.value); setError(null) }}
              disabled={!bougieId}
            />
            {depasseStock && (
              <p className="text-red-600 text-xs mt-1 flex items-center gap-1">
                <AlertTriangle className="w-3 h-3" /> Maximum disponible : {quantiteMax}
              </p>
            )}
            {alerteActive && (
              <p className="text-amber-600 text-xs mt-1 flex items-center gap-1">
                <AlertTriangle className="w-3 h-3" /> Après cette sortie, le stock passera sous le seuil d'alerte ({stockActuel.seuil_alerte})
              </p>
            )}
          </div>

          {/* Motif */}
          <div>
            <label className="block text-sm font-medium text-stone-700 mb-1">Motif (optionnel)</label>
            <input
              type="text"
              className="input-field"
              placeholder="ex : Messe du dimanche, Baptême…"
              value={motif}
              onChange={e => setMotif(e.target.value)}
            />
          </div>

          {/* Messages */}
          {error && (
            <div className="bg-red-50 border border-red-200 text-red-700 rounded-lg px-4 py-3 text-sm">
              {error}
            </div>
          )}
          {message && (
            <div className="bg-green-50 border border-green-200 text-green-700 rounded-lg px-4 py-3 text-sm">
              ✓ {message}
            </div>
          )}

          <button
            onClick={handleSortie}
            disabled={saving || !lieuId || !bougieId || !qte || depasseStock || quantiteSaisie <= 0}
            className="w-full flex items-center justify-center gap-2 bg-orange-600 hover:bg-orange-700 text-white font-medium px-4 py-2.5 rounded-lg transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
          >
            <MinusCircle className="w-4 h-4" />
            {saving ? 'Enregistrement…' : 'Confirmer la sortie'}
          </button>
        </div>
      </div>
    </div>
  )
}
